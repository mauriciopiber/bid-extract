{
  "name": "bid-extract",
  "version": "0.1.0",
  "description": "Multi-agent system for extracting structured data from bid tabulation PDFs",
  "type": "module",
  "scripts": {
    "cli": "tsx src/cli.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "check-types": "tsc --noEmit",
    "lint": "biome check src/",
    "format": "biome format --write src/"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.52.0",
    "commander": "^13.1.0",
    "dotenv": "^17.3.1",
    "drizzle-orm": "^0.45.1",
    "pdf-parse": "^1.1.1",
    "postgres": "^3.4.8",
    "sharp": "^0.34.1"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/node": "^22.14.0",
    "@types/pdf-parse": "^1.1.4",
    "drizzle-kit": "^0.31.10",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "vitest": "^3.1.1"
  },
  "volta": {
    "node": "24.12.0"
  }
}
